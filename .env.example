CMS_ADMIN_USERNAME="admin"
# Used only to initialize the SQLite admin account on first startup.
CMS_ADMIN_PASSWORD="replace-with-a-long-random-password"
# Domain used by the Docker Nginx HTTPS virtual host.
CMS_DOMAIN="example.com"
